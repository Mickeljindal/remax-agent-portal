# Supabase connection
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Use live data (not demo/showcase content)
VITE_PORTAL_SHOWCASE="false"

# KloudBean Node.js upload server (stores videos/files on the server disk)
VITE_UPLOAD_SERVER_URL="https://files.yourdomain.com"

# Optional: absolute site URL for share-link OG images
# VITE_PUBLIC_SITE_URL="https://portal.yourdomain.com"
