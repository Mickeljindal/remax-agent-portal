# Supabase connection
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# ─── SERVER-SIDE (KloudBean) ────────────────────────────────────────────────
# These power the Node backend (server.js): agent registration, admin password
# reset, email notifications, and pre-con worksheet submission. Set them in the
# KloudBean environment variables (NOT prefixed with VITE_, so they stay private).

# Supabase service role key — REQUIRED for registration / password reset / emails.
# Find it in Supabase: Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Resend email (https://resend.com). Without these, emails are logged but not sent.
RESEND_API_KEY="re_xxxxxxxxxxxxx"
NOTIFICATION_FROM_EMAIL="noreply@yourdomain.com"
PRECON_WORKSHEET_FROM_EMAIL="noreply@yourdomain.com"
PRECON_WORKSHEET_ADMIN_EMAIL="admin@yourdomain.com"
PORTAL_NAME="RE/MAX Excellence Portal"

# Public base URL of the app (used for uploaded file links)
PUBLIC_BASE_URL="https://agentportal.joinremaxex.com"

# Optional: where SENSITIVE files (client ID images from pre-con worksheets) are
# stored on disk. NOT served publicly — only admins can fetch them via the
# /api/worksheet-id endpoint. Defaults to ./private-uploads next to server.js.
# PRIVATE_UPLOAD_DIR="/var/data/private-uploads"

# Use live data (not demo/showcase content)
VITE_PORTAL_SHOWCASE="false"

# Frontend → backend base URL. Leave empty when the Node server serves both the
# app and the /api endpoints on the same domain (default KloudBean setup).
# Only set this if you run the upload/API server on a separate host.
VITE_UPLOAD_SERVER_URL=""

# Optional: absolute site URL for share-link OG images
# VITE_PUBLIC_SITE_URL="https://portal.yourdomain.com"
