# Port the upload server listens on (KloudBean assigns this)
PORT=4000

# Where files are stored on the KloudBean server disk
UPLOAD_DIR=/home/admin/portal-uploads

# Public URL of THIS upload server (your custom domain or KloudBean app URL)
PUBLIC_BASE_URL=https://files.remaxexcellence.ca

# Supabase JWT secret (Project Settings -> API -> JWT Settings -> JWT Secret)
# Used to verify the logged-in user's token before allowing uploads.
SUPABASE_JWT_SECRET=

# Comma-separated allowed frontend origins for CORS
ALLOWED_ORIGINS=https://portal.remaxexcellence.ca,http://localhost:8080
